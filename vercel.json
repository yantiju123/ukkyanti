{
  "version": 2,
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/api/setup.php",
      "dest": "/api/setup.php"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}