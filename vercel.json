{
  "version": 2,
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(assets|css|js|img|vendors)/(.*)",
      "dest": "/$1/$2",
      "continue": true
    },
    {
      "src": "/api/setup.php",
      "dest": "/api/setup.php"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}